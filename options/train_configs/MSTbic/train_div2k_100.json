{
  "task": "mstbic_swinir_lw_div2k_100",
  "model": "plain",
  "gpu_ids": null,
  "dist": false,

  "scale": 4,
  "n_channels": 3,
  "path": {
    "root": "superresolution",
    "pretrained_netG": "5500_G.pth"
  },

  "datasets": {
    "train": {
      "name": "train_dataset",
      "dataset_type": "mstbic",
      "dataroot_H": "data/MSTbic_100/train/HR",
      "dataroot_L": "data/MSTbic_100/train/LR",
      "H_size": 256,
      "dataloader_shuffle": true,
      "dataloader_num_workers": 2,
      "dataloader_batch_size": 4
    },
    "test": {
      "name": "test_dataset",
      "dataset_type": "mstbic",
      "dataroot_H": "data/MSTbic_100/val/HR",
      "dataroot_L": "data/MSTbic_100/val/LR",
      "H_size": 256,
      "dataloader_shuffle": false,
      "dataloader_num_workers": 1,
      "dataloader_batch_size": 1
    }
  },

  "netG": {
    "net_type": "swinir",
    "upscale": 4,
    "in_chans": 3,
    "img_size": 64,
    "window_size": 8,
    "img_range": 1.0,
    "depths": [6, 6, 6, 6],
    "embed_dim": 60,
    "num_heads": [6, 6, 6, 6],
    "mlp_ratio": 2,
    "upsampler": "pixelshuffledirect",
    "resi_connection": "1conv",
    "init_type": "default"
  },

  "train": {
    "G_lossfn_type": "mstbic",
    "G_lossfn_weight": 1.0,
    "E_decay": 0.999,
    
    "G_optimizer_type": "adam",
    "G_optimizer_lr": 2e-4,
    "G_optimizer_wd": 0,
    "G_optimizer_clipgrad": null,
    "G_optimizer_reuse": true,

    "G_scheduler_type": "MultiStepLR",
    "G_scheduler_milestones": [25000, 40000, 45000],
    "G_scheduler_gamma": 0.5,

    "G_param_strict": true,
    "E_param_strict": true,

    "checkpoint_test": 500,
    "checkpoint_save": 500,
    "checkpoint_print": 50
  }
}
